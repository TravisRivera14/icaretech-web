{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/app.py" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/admin", "destination": "/frontend/admin.html" },
    { "source": "/dashboard_cliente", "destination": "/frontend/dashboard_cliente.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}