{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/servicio",
      "dest": "servicio.html"
    },
    {
      "src": "/service",
      "dest": "servicio.html"
    },
    {
      "src": "/config_hacienda",
      "dest": "config_hacienda.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "assets/$1"
    },
    {
      "src": "/((?!api|servicio|service|config_hacienda).*\\.(png|jpg|jpeg|gif|ico|svg|css|js|db))",
      "dest": "$1"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}