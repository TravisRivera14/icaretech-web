{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app.py" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/registro", "dest": "/registro.html" },
    { "src": "/recuperar", "dest": "/recuperar.html" },
    { "src": "/dashboard_empresarial", "dest": "/dashboard_empresarial.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}