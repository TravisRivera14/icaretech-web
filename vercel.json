{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/app.py" },
    { "source": "/config_hacienda", "destination": "/src_frontend/config_hacienda.html" },
    { "source": "/servicio", "destination": "/src_frontend/servicio.html" },
    { "source": "/tienda", "destination": "/src_frontend/tienda.html" },
    { "source": "/admin", "destination": "/src_frontend/admin.html" },
    { "source": "/(.*)", "destination": "/src_frontend/$1" }
  ]
}