{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/admin.html",
      "dest": "frontend/admin.html"
    },
    {
      "src": "/servicio.html",
      "dest": "frontend/servicio.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}